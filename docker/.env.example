# ================================================
# TrankVPN - Конфигурация сервиса
# Скопируйте этот файл в .env и заполните значения
# ================================================

# === Telegram Bot ===
BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff_your_token
SUPPORT_USERNAME=your_support_username
# Telegram ID администраторов (через запятую)
ADMIN_IDS=123456789,987654321

# === CryptoPay (для приёма оплаты в USDT/TON) ===
# Получите токен у @CryptoBot -> /pay -> Create App
CRYPTO_BOT_TOKEN=your_cryptobot_token

# === База данных MariaDB ===
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=vpn_service
DB_USER=vpn_user
DB_PASS=your_strong_db_password_here
MYSQL_ROOT_PASSWORD=your_strong_root_password_here

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# === Marzban VPN Panel ===
# URL вашей панели Marzban (внутри Docker-сети или внешний)
MARZBAN_URL=http://marzban:8000
MARZBAN_ADMIN=admin
MARZBAN_PASS=your_marzban_admin_password

# === Шифрование ===
# Генерация: python3 -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=your_base64_encryption_key_here

# === Домен и веб ===
DOMAIN=vpn.yourdomain.com
WEB_APP_URL=https://vpn.yourdomain.com
